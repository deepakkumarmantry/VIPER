{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "environmentName": {
      "value": "${AZURE_ENV_NAME}"
    },
    "location": {
      "value": "${AZURE_LOCATION}"
    },
    "azureOpenaiGptVisionApiKey": {
      "value": "${AZURE_OPENAI_GPT_VISION_API_KEY}"
    },
    "azureOpenaiGptVisionEndpoint": {
      "value": "${AZURE_OPENAI_GPT_VISION_ENDPOINT}"
    },
    "azureOpenaiGptVisionApiVersion": {
      "value": "${AZURE_OPENAI_GPT_VISION_API_VERSION}"
    },
    "azureOpenaiGptVisionDeployment": {
      "value": "${AZURE_OPENAI_GPT_VISION_DEPLOYMENT}"
    },
    "azureOpenaiGptVisionResourceId": {
      "value": "${AZURE_OPENAI_GPT_VISION_RESOURCE_ID}"
    },
    "azureSpeechRegion": {
      "value": "${AZURE_SPEECH_REGION}"
    },
    "azureSpeechUseManagedIdentity": {
      "value": "${AZURE_SPEECH_USE_MANAGED_IDENTITY}"
    },
    "azureSpeechResourceId": {
      "value": "${AZURE_SPEECH_RESOURCE_ID}"
    },
    "enableFrontend": {
      "value": "${ENABLE_FRONTEND}"
    },
    "azureStorageAccountUrl": {
      "value": "${AZURE_STORAGE_ACCOUNT_URL}"
    },
    "azureSearchEndpoint": {
      "value": "${AZURE_SEARCH_ENDPOINT}"
    },
    "azOpenaiKey": {
      "value": "${AZ_OPENAI_KEY}"
    },
    "azOpenaiBase": {
      "value": "${AZ_OPENAI_BASE}"
    },
    "azOpenaiVersion": {
      "value": "${AZ_OPENAI_VERSION}"
    },
    "gpt4": {
      "value": "${GPT4}"
    },
    "searchEndpoint": {
      "value": "${SEARCH_ENDPOINT}"
    },
    "searchApiKey": {
      "value": "${SEARCH_API_KEY}"
    },
    "searchIndexName": {
      "value": "${AZURE_SEARCH_INDEX_NAME}"
    },
    "storageVideoContainer": {
      "value": "${AZURE_STORAGE_VIDEO_CONTAINER}"
    },
    "storageOutputContainer": {
      "value": "${AZURE_STORAGE_OUTPUT_CONTAINER}"
    },
    "databaseUrl": {
      "value": "${DATABASE_URL}"
    },
    "viperAuthMode": {
      "value": "${VIPER_AUTH_MODE}"
    },
    "viperAdminEmails": {
      "value": "${VIPER_ADMIN_EMAILS}"
    },
    "frontendEasyAuthEnabled": {
      "value": "${FRONTEND_EASYAUTH_ENABLED}"
    },
    "frontendEasyAuthClientId": {
      "value": "${FRONTEND_EASYAUTH_CLIENT_ID}"
    },
    "frontendEasyAuthClientSecret": {
      "value": "${FRONTEND_EASYAUTH_CLIENT_SECRET}"
    },
    "frontendEasyAuthOpenIdIssuer": {
      "value": "${FRONTEND_EASYAUTH_OPENID_ISSUER}"
    },
    "createPostgres": {
      "value": "${CREATE_POSTGRES}"
    },
    "postgresServerName": {
      "value": "${POSTGRES_SERVER_NAME}"
    },
    "postgresAdministratorLogin": {
      "value": "${POSTGRES_ADMINISTRATOR_LOGIN}"
    },
    "postgresAdministratorPassword": {
      "value": "${POSTGRES_ADMINISTRATOR_PASSWORD}"
    },
    "postgresDatabaseName": {
      "value": "${POSTGRES_DATABASE_NAME}"
    }
  }
}
