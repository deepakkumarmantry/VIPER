# Sample environment configuration for the Viper solution.
# Copy this file to `.env` in the repository root and populate the values
# before running the backend or frontend services.

# --- Viper backend configuration ---
# Leave API keys blank to use Entra ID authentication.
AZURE_OPENAI_GPT_VISION_API_KEY=""
AZURE_OPENAI_GPT_VISION_ENDPOINT=""
AZURE_OPENAI_GPT_VISION_API_VERSION="2024-06-01"
AZURE_OPENAI_GPT_VISION_DEPLOYMENT="gpt4o"
# Required for deployment-time backend managed identity RBAC when using Entra ID.
AZURE_OPENAI_GPT_VISION_RESOURCE_ID=""

AZURE_SPEECH_REGION=""
# AZURE_SPEECH_ENDPOINT=""
AZURE_SPEECH_USE_MANAGED_IDENTITY="true"
# Required for Speech SDK Entra ID authentication.
AZURE_SPEECH_RESOURCE_ID=""
# AZURE_SPEECH_API_KEY=""
# AZURE_SPEECH_MANAGED_IDENTITY_CLIENT_ID=""

AZURE_STORAGE_ACCOUNT_URL=""
# AZURE_STORAGE_ACCOUNT_NAME=""
AZURE_STORAGE_VIDEO_CONTAINER="videos"
AZURE_STORAGE_OUTPUT_CONTAINER="analysis"
# AZURE_STORAGE_MANAGED_IDENTITY_CLIENT_ID=""

AZURE_SEARCH_ENDPOINT=""
AZURE_SEARCH_INDEX_NAME=""

# Set to false for backend-only COBRA API deployments.
ENABLE_FRONTEND="true"
# AZURE_SEARCH_API_KEY=""
# AZURE_SEARCH_MANAGED_IDENTITY_CLIENT_ID=""

# --- Viper UI (Next.js) configuration ---
AZ_OPENAI_KEY=
AZ_OPENAI_BASE=
AZ_OPENAI_VERSION=
# AZ_OPENAI_REG=
GPT4=4turbo

SEARCH_ENDPOINT=
SEARCH_API_KEY=
INDEX_NAME=

# VIPER UI auth defaults to Azure Container Apps EasyAuth with Entra ID.
VIPER_AUTH_MODE="easyauth"
# Comma-separated Entra user emails that should receive platform admin role.
VIPER_ADMIN_EMAILS=""

# Set CREATE_POSTGRES=true to let azd provision a PostgreSQL Flexible Server for
# the full-stack UI. Leave false when supplying a bring-your-own DATABASE_URL.
CREATE_POSTGRES="true"
POSTGRES_SERVER_NAME=""
POSTGRES_ADMINISTRATOR_LOGIN="viperadmin"
POSTGRES_ADMINISTRATOR_PASSWORD=""
POSTGRES_DATABASE_NAME="viper"

DATABASE_URL=""

# Container Apps EasyAuth requires a customer/tenant Entra app registration.
FRONTEND_EASYAUTH_ENABLED="true"
FRONTEND_EASYAUTH_CLIENT_ID=""
FRONTEND_EASYAUTH_CLIENT_SECRET=""
# Leave blank to use the deployment tenant issuer.
FRONTEND_EASYAUTH_OPENID_ISSUER=""

# Explicit non-production local smoke-test mode. Do not enable in customer Azure deployments.
# VIPER_AUTH_MODE="anonymous"
# VIPER_ANONYMOUS_EMAIL="anonymous@localhost"
# VIPER_ANONYMOUS_NAME="Local test user"
# VIPER_ANONYMOUS_ORGANIZATION_SLUG="local-test"
# VIPER_ANONYMOUS_ORGANIZATION_NAME="Local Test Organization"
# VIPER_ANONYMOUS_COLLECTION_NAME="Local Test Videos"

# Optional overrides for Viper backend endpoints (defaults to http://localhost:8000)
# VIPER_BASE_URL="http://localhost:8000"

# VIPER_BACKEND_INTERNAL_URL="http://localhost:8000"

# ACTION_SUMMARY_ENDPOINT="http://localhost:8000/analysis/action-summary"
# CHAPTER_ANALYSIS_ENDPOINT="http://localhost:8000/analysis/chapter-analysis"
# COBRAPY_UPLOAD_ENDPOINT="http://localhost:8000/videos/upload"
